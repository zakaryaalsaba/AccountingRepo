PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/accounting_saas
# Managed Postgres (e.g. DigitalOcean): download CA from cluster → server/ca-certificate.crt (committed copy)
# or set DB_CA_CERT (PEM) / DB_CA_CERT_PATH. See server/src/db.js.
# Note: when using explicit ssl.ca in code, `sslmode=require` is stripped from DATABASE_URL at runtime
# to avoid pg merging URL sslmode with Pool ssl (fixes some SELF_SIGNED_CERT_IN_CHAIN cases).
# Optional: log full CA PEM in Runtime Logs (remove after debugging)
# DB_DEBUG_SSL=true
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# Document signing (e-sign) — storage (MVP: local disk). See server/src/modules/documents/storage/README.md
# ESIGN_STORAGE_DRIVER=local
# ESIGN_UPLOAD_DIR=uploads/esign
# ESIGN_PUBLIC_BASE_URL=http://localhost:4000
# ESIGN_PUBLIC_URL_PATH=/files/esign
# ESIGN_MAX_FILE_BYTES=15728640
# ESIGN_ALLOWED_MIME=application/pdf
# Signing links & public POST /sign throttling
# ESIGN_TOKEN_TTL_DAYS=14
# ESIGN_SIGN_RATE_LIMIT_WINDOW_MS=900000
# ESIGN_SIGN_RATE_LIMIT_MAX=20
# DOCUMENTS_MODULE_ENABLED=1
# Optional override for links returned by POST .../send (default: ESIGN_PUBLIC_BASE_URL + /api/sign)
# ESIGN_SIGNING_BASE_URL=http://localhost:4000/api/sign
# Public signing JSON body size (base64 images); mounted only on /api/sign and /sign
# ESIGN_SIGN_JSON_LIMIT=15mb
# Optional CORS allowlist for signing routes only (comma-separated origins). Omit for same behavior as global CORS (any origin).
# ESIGN_PUBLIC_SIGNING_ORIGINS=https://app.example.com,https://sign.example.com
